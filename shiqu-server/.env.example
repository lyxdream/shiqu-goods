# 本地开发环境变量模板
# 使用：cp .env.example .env 后按需修改
# 生产部署：见 .env.production 与项目根目录 DEPLOYMENT.md

# App
PORT=3000
NODE_ENV=development
# 反向代理层数：开发直连用 false；生产单层 Nginx 用 1（CDN+Nginx 等多层时按实际 hop 数调整）
TRUST_PROXY=false

# API 域名（生产环境 ApiHostMiddleware 使用；本地开发一般不影响）
API_HOST=api.shiqu.com
ADMIN_API_HOST=admin-api.shiqu.com

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shiqu_goods
# 开发建议 true（自动同步表结构）；生产必须 false，改用 npm run migration:run
DB_SYNC=true

# JWT - C 端用户
# 开发可用任意字符串；生产须 openssl rand -hex 32（见 .env.production）
JWT_SECRET=shiqu-user-jwt-secret-change-me
# 用户 Token 有效期（天），对应 jwt.config.ts 中的 JWT_EXPIRES_IN_DAYS
JWT_EXPIRES_IN_DAYS=7

# JWT - B 端管理员
# 开发可用任意字符串；生产须 openssl rand -hex 32，且与 JWT_SECRET 不同
ADMIN_JWT_SECRET=shiqu-admin-jwt-secret-change-me
ADMIN_JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
# 单文件上限（字节），5242880 = 5MB
UPLOAD_MAX_SIZE=5242880

# Seed 管理员初始化
# SEED_ADMIN_USERNAME：管理员用户名
# SEED_ADMIN_PASSWORD_DEFAULT：开发环境默认密码（生产不生效）
# SEED_ADMIN_PASSWORD：生产环境必须通过命令行传入，勿写入 .env
# 示例：SEED_ADMIN_PASSWORD=你的强密码 npm run seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD_DEFAULT=admin123
SEED_ADMIN_PASSWORD=

# Order（待付款超时自动取消，单位：分钟，默认 30）
ORDER_PENDING_TIMEOUT_MINUTES=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# 本地开发通常留空；生产须与 Redis 服务端 requirepass 一致
REDIS_PASSWORD=

# 限流（次/THROTTLE_TTL_MS 毫秒窗口，默认 60 秒）
# 三条命名规则：default（普通）/ strict（认证）/ ai（AI）
# 各 Controller 通过 @DefaultThrottled / @StrictAuth / @AiChat 等装饰器选择生效规则
THROTTLE_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_LIMIT=5
THROTTLE_OTP_LIMIT=3
THROTTLE_AI_CHAT_LIMIT=20
THROTTLE_AI_DOCUMENT_LIMIT=5

# AI Service
AI_SERVICE_URL=http://localhost:8000
# 与 shiqu-ai/.env 的 INTERNAL_SECRET 保持一致；开发环境为空则跳过校验
AI_INTERNAL_SECRET=

# Swagger（开发默认开启；生产默认关闭，见 .env.production）
SWAGGER_ENABLED=true
