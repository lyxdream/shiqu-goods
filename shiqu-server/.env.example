# App
PORT=3000
NODE_ENV=development

# API 域名（生产环境 api-host 中间件使用）
API_HOST=api.shiqu.com
ADMIN_API_HOST=admin-api.shiqu.com

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shiqu_goods
DB_SYNC=true

# JWT - C 端用户
JWT_SECRET=shiqu-user-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# JWT - B 端管理员
ADMIN_JWT_SECRET=shiqu-admin-jwt-secret-change-me
ADMIN_JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=5242880

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Swagger
SWAGGER_ENABLED=true
