# App
PORT=3000
NODE_ENV=development

# API 域名（生产环境 api-host 中间件使用）
API_HOST=api.shiqu.com
ADMIN_API_HOST=admin-api.shiqu.com

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shiqu_goods
DB_SYNC=false

# JWT - C 端用户
JWT_SECRET=shiqu-user-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# JWT - B 端管理员
ADMIN_JWT_SECRET=shiqu-admin-jwt-secret-change-me
ADMIN_JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=5242880

# Seed 管理员初始化
# SEED_ADMIN_USERNAME：管理员用户名
# SEED_ADMIN_PASSWORD_DEFAULT：开发环境默认密码（生产不生效）
# SEED_ADMIN_PASSWORD：生产环境必须通过此变量传入，否则脚本拒绝执行
# 示例：SEED_ADMIN_PASSWORD=你的强密码 npm run seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD_DEFAULT=admin123
SEED_ADMIN_PASSWORD=

# Order（待付款超时自动取消，单位：分钟，默认 30）
ORDER_PENDING_TIMEOUT_MINUTES=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 限流（次/THROTTLE_TTL_MS 毫秒窗口，默认 60 秒）
# 三条命名规则：default（普通）/ strict（认证）/ ai（AI）
# 各 Controller 通过 @DefaultThrottled / @StrictAuth / @AiChat 等装饰器选择生效规则
THROTTLE_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_LIMIT=5
THROTTLE_OTP_LIMIT=3
THROTTLE_AI_CHAT_LIMIT=20
THROTTLE_AI_DOCUMENT_LIMIT=5

# AI Service
AI_SERVICE_URL=http://localhost:8000
# 与 shiqu-ai 的 INTERNAL_SECRET 保持一致，为空则跳过校验（仅开发环境）
AI_INTERNAL_SECRET=

# Swagger（生产环境默认关闭，需显式设为 true 才开启；开发环境默认开启）
SWAGGER_ENABLED=false
