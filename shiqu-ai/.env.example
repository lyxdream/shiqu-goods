APP_NAME=shiqu-ai
APP_HOST=0.0.0.0
APP_PORT=8000

# ── LLM 配置 ──────────────────────────────────────────
# LLM_ENABLED=true 时启用大模型，false 时使用规则引擎兜底
LLM_ENABLED=false
LLM_API_KEY=  # 填入你的 DeepSeek API Key
LLM_BASE_URL=https://api.deepseek.com
# deepseek-v4-flash（快速低成本）或 deepseek-v4-pro（效果最佳）
LLM_MODEL=deepseek-v4-flash
