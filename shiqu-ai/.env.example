APP_NAME=shiqu-ai
APP_HOST=127.0.0.1
APP_PORT=8000
# development | production（production 时强制校验 INTERNAL_SECRET，关闭 /docs）
APP_ENV=development

# 内部调用鉴权密钥（与 shiqu-server 的 AI_INTERNAL_SECRET 保持一致）
# 生产环境（APP_ENV=production）必填，为空时服务拒绝启动
INTERNAL_SECRET=

# ── LLM 配置 ──────────────────────────────────────────
# LLM_ENABLED=true 时启用大模型，false 时使用规则引擎兜底
LLM_ENABLED=false
LLM_API_KEY=  # 填入你的 DeepSeek API Key
LLM_BASE_URL=https://api.deepseek.com
# deepseek-v4-flash（快速低成本）或 deepseek-v4-pro（效果最佳）
LLM_MODEL=deepseek-v4-flash
