# 本地开发环境变量模板
# 使用：cp .env.example .env 后按需修改
# 生产部署：见 .env.production 与项目根目录 DEPLOYMENT.md

APP_NAME=shiqu-ai
APP_HOST=127.0.0.1
APP_PORT=8000
# development | production（production 时强制校验 INTERNAL_SECRET，关闭 /docs）
APP_ENV=development

# 内部调用鉴权密钥（与 shiqu-server/.env 的 AI_INTERNAL_SECRET 保持一致）
# 开发环境可为空（跳过校验）；生产须 openssl rand -hex 32（见 .env.production）
INTERNAL_SECRET=

# ── LLM 配置 ──────────────────────────────────────────
# LLM_ENABLED=true 时启用大模型，false 时使用规则引擎兜底
LLM_ENABLED=false
# 启用 LLM 时必填，从 DeepSeek 等平台获取 API Key
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
# deepseek-chat（效果较好）或 deepseek-v3-0324（更快更省）
LLM_MODEL=deepseek-chat
